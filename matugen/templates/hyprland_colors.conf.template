# ~/.config/matugen/templates/hyprland.conf
general {
    col.active_border = rgba({{colors.primary.default.hex_stripped}}ff) rgba({{colors.secondary.default.hex_stripped}}ff) 45deg
    col.inactive_border = rgba({{colors.surface.default.hex_stripped}}aa)
}

group {
    col.border_active = rgba({{colors.primary.default.hex_stripped}}ff)
    col.border_inactive = rgba({{colors.surface.default.hex_stripped}}aa)
}

